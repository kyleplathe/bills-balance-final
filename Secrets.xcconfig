// Local secrets — keep out of version control if the repo is shared.
// Values mirror .env.local (SUPABASE_ANON_KEY is the publishable/anon key used by the app).

// xcconfig treats "//" as a line comment, so never write "https://..." literally — build the URL from pieces.
SLASH = /
DOUBLE_SLASH = $(SLASH)$(SLASH)
SUPABASE_HOST = ydcvzmbafxtrwhrodrvk.supabase.co
SUPABASE_URL = https:$(DOUBLE_SLASH)$(SUPABASE_HOST)

SUPABASE_ANON_KEY = sb_publishable_8MMuGvJyhrqT_g5M0J9LjA_3tYsByQo
